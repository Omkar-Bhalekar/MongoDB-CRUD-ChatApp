<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Chat</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white border border-gray-200 rounded-lg shadow-sm w-full max-w-sm p-5">

        <h2 class="text-sm font-medium text-gray-700 mb-4">New Chat</h2>

        <hr class="border-gray-100 mb-4">

        <form method="post" action="/chats/new" class="space-y-3">

            <div class="flex flex-col gap-1">
                <label class="text-xs text-gray-400">From</label>
                <input
                    type="text"
                    placeholder="Enter your name"
                    name="from"
                    class="border border-gray-200 rounded-md px-3 py-2 text-sm text-gray-800 placeholder-gray-300 outline-none focus:border-gray-400"
                >
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-xs text-gray-400">To</label>
                <input
                    type="text"
                    placeholder="Enter receiver name"
                    name="to"
                    class="border border-gray-200 rounded-md px-3 py-2 text-sm text-gray-800 placeholder-gray-300 outline-none focus:border-gray-400"
                >
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-xs text-gray-400">Message</label>
                <input
                    type="text"
                    placeholder="Enter your message"
                    name="message"
                    class="border border-gray-200 rounded-md px-3 py-2 text-sm text-gray-800 placeholder-gray-300 outline-none focus:border-gray-400"
                >
            </div>

            <button
                type="submit"
                class="w-full mt-1 bg-gray-800 text-white text-sm rounded-md py-2 hover:bg-gray-700 transition-colors"
            >
                Send
            </button>

        </form>

    </div>

</body>
</html>