<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chats</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50 min-h-screen p-6">

    <div class="max-w-5xl mx-auto mb-4 flex items-center justify-between">
        <h1 class="text-sm font-medium text-gray-700">Chats</h1>

        <a href="/chats/new"
            class="bg-gray-800 text-white text-xs rounded-md px-3 py-2 hover:bg-gray-700 transition-colors">
            + New Chat
        </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">

        <% if (data.length===0) { %>
            <p class="text-gray-400 text-sm text-center col-span-3">No chats yet. Start one!</p>
            <% } %>

                <% data.forEach(function(chat) { %>

                    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-5">

                        <!-- From / To -->
                        <div class="mb-4 text-sm space-y-1">
                            <div class="flex gap-2">
                                <span class="text-gray-400 w-8">From</span>
                                <span class="text-gray-800">
                                    <%= chat.from %>
                                </span>
                            </div>

                            <div class="flex gap-2">
                                <span class="text-gray-400 w-8">To</span>
                                <span class="text-gray-800">
                                    <%= chat.to %>
                                </span>
                            </div>
                        </div>

                        <hr class="border-gray-100 mb-4">

                        <!-- Message -->
                        <p class="text-gray-800 text-sm leading-relaxed mb-4">
                            <%= chat.message %>
                        </p>

                        <div class="flex flex-col items-end mt-2">

                            <!-- Created Time -->
                            <p class="text-xs text-gray-400">
                                <%= new Date(chat.created_at).toLocaleTimeString() %>
                            </p>

                            <p class="text-xs text-gray-400">
                                <%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %>
                </p>

                <!-- Updated Time -->
                <% if (chat.updated_at) { %>
                    <p class=" text-xs text-gray-400">
                                    Edited at: <%= new Date(chat.updated_at).toLocaleTimeString() %>
                            </p>
                            <p class="text-xs text-gray-400">
                                <%= new Date(chat.updated_at).toDateString() %>
                            </p>
                            <% } %>

                                <!-- Buttons -->
                                <div class="flex items-center gap-2 mt-5">

                                    <a href="/chats/<%= chat.id %>/edit"
                                        class="text-xs text-gray-600 px-2 py-0.5 hover:text-black transition-colors">
                                        Edit
                                    </a>

                                    <form method="post" action="/chats/<%= chat.id %>/delete?_method=DELETE"
                                        class="inline flex items-center" onsubmit="return confirm('Delete this chat?')">
                                        <button
                                            class="text-xs text-gray-600 px-2 py-0.5 hover:text-black transition-colors">
                                            Delete
                                        </button>
                                    </form>

                                </div>

                        </div>

                    </div>

                    <% }); %>

    </div>

</body>

</html>